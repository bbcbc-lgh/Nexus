# 数据库连接
# 格式：mysql+aiomysql://用户名:密码@主机:端口/数据库名
# 示例：mysql+aiomysql://root:your_password@localhost:3306/your_db_name?charset=utf8mb4
DATABASE_URL=mysql+aiomysql://your_user:your_password@localhost:3306/your_db_name?charset=utf8mb4

# Redis 配置
# 如果使用 Docker 容器且已映射端口（-p 6379:6379），主机填 localhost 即可
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# CORS 允许的前端域名，多个域名用英文逗号分隔（不能有空格）
# 开发环境示例：http://localhost:5173
# 生产环境示例：https://your-domain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8100

# 服务器对外访问地址，用于生成头像等资源的完整 URL
# 生产环境示例：https://your-domain.com
BASE_URL=http://localhost:8000
